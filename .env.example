# Zkopíruj tento soubor jako .env a vyplň hodnoty
# cp .env.example .env

# ─── Claude API ───────────────────────────────────────────────────────────────
# Získáš na: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Model pro generování příspěvků (výchozí: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# ─── Gmail ────────────────────────────────────────────────────────────────────
# Tvůj Gmail nebo Google Workspace účet, ze kterého se bude posílat e-mail.
# NUTNÉ: zapni 2FA a vygeneruj App Password na:
#   https://myaccount.google.com/apppasswords
#   (kategorie: Mail, zařízení: Other – např. "GatorsAgent")
GMAIL_ADDRESS=vas-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# E-mail, kam se bude posílat příspěvek ke schválení
RECIPIENT_EMAIL=krystof.novak@gnj.cz

# ─── SMTP (výchozí nastavení funguje pro Gmail) ───────────────────────────────
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
